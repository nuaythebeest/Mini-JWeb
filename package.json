{
  "name": "mini-jweb-ex",
  "version": "0.6.0-beta.4-rc1",
  "description": "Local desktop prototype for configuring Juniper EX switches with a simplified J-Web style GUI.",
  "author": {
    "name": "Pichan Pratummal"
  },
  "main": "src/main/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env MINI_JWEB_DEV_SERVER=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "package:mac": "electron-builder --mac --arm64",
    "package:mac:x64": "electron-builder --mac --x64",
    "package:win": "electron-builder --win nsis --x64",
    "package:win:msi": "electron-builder --win msi --x64",
    "package:win:zip": "electron-builder --win zip --x64",
    "package:win:arm64": "electron-builder --win --arm64"
  },
  "dependencies": {
    "sha512-crypt-ts": "^0.1.27",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.local.minijwebex.windows.stable",
    "productName": "Mini J-Web EX Windows",
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "src/preload/**/*",
      "!node_modules/cpu-features/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "artifactName": "${productName} Setup ${version}-${arch}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false,
      "uninstallDisplayName": "Mini J-Web EX Windows",
      "include": "build/installer.nsh"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mini J-Web EX Windows"
    }
  }
}
